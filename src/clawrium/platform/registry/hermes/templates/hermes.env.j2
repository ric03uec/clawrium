{# NOTE (#560 Phase 2): This file is the LEGACY ansible-driven template
   consumed by `playbooks/configure.yaml` and the `clawctl agent configure`
   wizard. It uses the old `config.provider.type` / `config.channels.discord`
   extravar shape and is NOT used by `clawctl agent sync` (canonical
   pipeline), which renders via `hermes-env.canonical.j2` through
   `render_hermes()` in core/render.py. Two template families coexist
   pending the consolidation follow-up — see PR #567 Callouts. Field
   changes to one family MUST land in both until consolidation. #}
{# Shell-safe quoting: single-quote values and escape embedded single quotes.
   POSIX shell quoting: 'val'"'"'ue' embeds a single quote in a single-quoted
   string. systemd EnvironmentFile treats `#` as a comment start mid-value, so
   anything user-supplied must be quoted. #}
{%- macro shell_quote(value) -%}
'{{ value | string | replace("'", "'\"'\"'") }}'
{%- endmacro -%}
# Managed by clawrium (clawctl). Do not edit by hand — re-render with
# `clawctl agent configure {{ agent_name }}`.
#
# Provider API keys.
#
# #614: hermes multi-provider — `config.providers[]` carries one entry per
# attachment (primary + auxiliaries). We emit ONE `*_API_KEY` line per
# unique provider type. Same-type duplicates collapse onto the primary's
# key with a `# WARNING` comment (upstream hermes reads one env-var per
# type, so last-wins systemd semantics would silently keep one and the
# operator would have no signal). Bedrock keeps the AWS triplet
# (one set of credentials per region).
#
# Singleton fallback: when `config.providers` is absent (un-migrated
# tests / pre-#613 hosts.json shapes), we fall back to the legacy
# `config.provider` + `provider_api_key` / `aws_*` scalars.
{% set _providers_list = config.providers | default([]) %}
{% set _provider_api_keys = provider_api_keys | default({}) %}
{% set _provider_aws_credentials = provider_aws_credentials | default({}) %}
{% if _providers_list | length > 0 %}
{# Walk providers in attachment order (primary first per lifecycle.py's
   _build_provider_overlay loop). First key per type wins; subsequent
   same-type entries either match (drop silently) or conflict (emit
   WARNING). #}
{% set _seen_type_keys = {} %}
{% set _conflicts = [] %}
{% for _p in _providers_list %}
{% set _ptype = _p.type | default('') %}
{% if _ptype == 'bedrock' %}
{% set _aws = _provider_aws_credentials.get(_p.name, {}) %}
{% set _key_compare = (_aws.get('access_key', '') ~ '|' ~ _aws.get('secret_key', '')) %}
{% if _ptype not in _seen_type_keys %}
{# ATX iter-1 W2: register the type slot UNCONDITIONALLY on first sight.
   If the primary has empty creds and we only registered after the
   emission guard, a subsequent same-type aux would claim the slot —
   primary-wins would invert. #}
{% if _seen_type_keys.update({_ptype: _key_compare}) %}{% endif %}
{% if _aws.get('access_key') and _aws.get('secret_key') %}
AWS_ACCESS_KEY_ID={{ shell_quote(_aws.get('access_key', '')) }}
AWS_SECRET_ACCESS_KEY={{ shell_quote(_aws.get('secret_key', '')) }}
{% set _region = _aws.get('region', '') or _p.region | default('') %}
{% if _region %}
AWS_DEFAULT_REGION={{ shell_quote(_region) }}
{% else %}
AWS_DEFAULT_REGION=us-east-1
{% endif %}
{% endif %}
{% elif _seen_type_keys[_ptype] != _key_compare %}
{% if _conflicts.append(_ptype) %}{% endif %}
{% endif %}
{% else %}
{% set _key = _provider_api_keys.get(_p.name, '') %}
{% if _ptype not in _seen_type_keys %}
{# ATX iter-1 W2: register unconditionally on first sight; the
   emission guard only suppresses the key line when the credential is
   missing. This keeps primary-wins intact even when the primary has
   no key configured. #}
{% if _seen_type_keys.update({_ptype: _key}) %}{% endif %}
{% if _key %}
{% if _ptype == 'openrouter' %}
OPENROUTER_API_KEY={{ shell_quote(_key) }}
{% elif _ptype == 'anthropic' %}
ANTHROPIC_API_KEY={{ shell_quote(_key) }}
{% elif _ptype == 'openai' %}
OPENAI_API_KEY={{ shell_quote(_key) }}
{% endif %}
{% endif %}
{% elif _seen_type_keys[_ptype] != _key %}
{% if _conflicts.append(_ptype) %}{% endif %}
{% endif %}
{% endif %}
{% endfor %}
{% for _ctype in _conflicts %}
{# ATX iter-1 W5: sanitize CR/LF/NUL on the type string so a crafted
   providers.json `type: "openrouter\nMALICIOUS_KEY=..."` cannot break
   out of the comment line and inject a new env assignment. #}
# WARNING: multiple {{ _ctype | replace('\n', '') | replace('\r', '') | replace('\x00', '') }} providers attached with different API keys;
# hermes reads one env var per provider type, so only the primary's key
# above is honored. Detach the conflicting attachment or rotate it to
# share the primary's key.
{% endfor %}
{% else %}
{# Singleton back-compat path: pre-#613 hosts.json shape or tests that
   pass only `config.provider`. #}
{% if config.provider is defined and config.provider.type == 'openrouter' and provider_api_key | default('') | length > 0 %}
OPENROUTER_API_KEY={{ shell_quote(provider_api_key) }}
{% elif config.provider is defined and config.provider.type == 'anthropic' and provider_api_key | default('') | length > 0 %}
ANTHROPIC_API_KEY={{ shell_quote(provider_api_key) }}
{% elif config.provider is defined and config.provider.type == 'openai' and provider_api_key | default('') | length > 0 %}
OPENAI_API_KEY={{ shell_quote(provider_api_key) }}
{% elif config.provider is defined and config.provider.type == 'bedrock' and aws_access_key | default('') | length > 0 and aws_secret_key | default('') | length > 0 %}
AWS_ACCESS_KEY_ID={{ shell_quote(aws_access_key) }}
AWS_SECRET_ACCESS_KEY={{ shell_quote(aws_secret_key) }}
{% if config.provider.region | default('') | length > 0 %}
AWS_DEFAULT_REGION={{ shell_quote(config.provider.region) }}
{% else %}
AWS_DEFAULT_REGION=us-east-1
{% endif %}
{% endif %}
{% endif %}

# Provider/model selection. config.yaml's `model:` block is the canonical
# source — these env vars are emitted as a low-priority fallback.
{% if config.provider is defined and config.provider.type %}
{% if config.provider.type == 'ollama' %}
HERMES_INFERENCE_PROVIDER=custom
{% else %}
HERMES_INFERENCE_PROVIDER={{ shell_quote(config.provider.type) }}
{% endif %}
{% endif %}

# API server (local OpenAI-compatible gateway on 127.0.0.1:8642).
{% set api_server = config.api_server | default({}) %}
API_SERVER_ENABLED=1
API_SERVER_HOST={{ shell_quote(api_server.host | default('127.0.0.1')) }}
API_SERVER_PORT={{ api_server.port | default(8642) | int }}
API_SERVER_KEY={{ shell_quote(api_server.key) }}

# Discord platform (only emitted when channels.discord.enabled and token
# present). bot_token is hydrated from secrets.json by lifecycle.configure_agent
# and stripped from hosts.json by install.py's updater closure (B3 invariant).
# Use dict.get() pattern (not attribute access) so undefined keys don't error
# under Ansible 2.20+'s strict Jinja mode.
{% set channels = config.channels | default({}) %}
{% set discord = channels.get('discord', {}) if channels else {} %}
{% if discord.get('enabled') and discord.get('bot_token') %}
DISCORD_BOT_TOKEN={{ shell_quote(discord.get('bot_token')) }}
{% if discord.get('allowed_users') %}
DISCORD_ALLOWED_USERS={{ shell_quote(discord.get('allowed_users') | join(',')) }}
{% endif %}
{% if discord.get('allow_all_users') %}
DISCORD_ALLOW_ALL_USERS=true
{% endif %}
{% if discord.get('home_channel') %}
DISCORD_HOME_CHANNEL={{ shell_quote(discord.get('home_channel')) }}
{% endif %}
{% if discord.get('home_channel_name') %}
DISCORD_HOME_CHANNEL_NAME={{ shell_quote(discord.get('home_channel_name')) }}
{% endif %}
{% if discord.get('home_channel_thread_id') %}
DISCORD_HOME_CHANNEL_THREAD_ID={{ shell_quote(discord.get('home_channel_thread_id')) }}
{% endif %}
{% if discord.get('allowed_channels') %}
DISCORD_ALLOWED_CHANNELS={{ shell_quote(discord.get('allowed_channels') | join(',')) }}
{% endif %}
{% if 'require_mention' in discord %}
DISCORD_REQUIRE_MENTION={{ shell_quote(discord.get('require_mention') | string | lower) }}
{% endif %}
{% endif %}

# Slack platform (only emitted when channels.slack.enabled and tokens
# present). bot_token and app_token are hydrated from secrets.json by
# lifecycle.configure_agent and stripped from hosts.json (B3 invariant).
{% set slack = channels.get('slack', {}) if channels else {} %}
{% if slack.get('enabled') and slack.get('bot_token') and slack.get('app_token') %}
SLACK_BOT_TOKEN={{ shell_quote(slack.get('bot_token')) }}
SLACK_APP_TOKEN={{ shell_quote(slack.get('app_token')) }}
{% if slack.get('allowed_users') %}
SLACK_ALLOWED_USERS={{ shell_quote(slack.get('allowed_users') | join(',')) }}
{% endif %}
{% if slack.get('home_channel') %}
SLACK_HOME_CHANNEL={{ shell_quote(slack.get('home_channel')) }}
{% endif %}
{% if slack.get('home_channel_name') %}
SLACK_HOME_CHANNEL_NAME={{ shell_quote(slack.get('home_channel_name')) }}
{% endif %}
{% endif %}

{# --- Integration credentials ------------------------------------------
   Per-integration env vars for skills and tools that read tokens directly
   (e.g. the `gh` CLI's GITHUB_TOKEN, hermes skills calling the GitHub API).
   Per-name vars (GITHUB_TOKEN_<NAME>) support multi-account setups; the
   bare GITHUB_TOKEN is set to the alphabetically-last github integration
   for back-compat with skills that hard-code the canonical name (via
   `dictsort` so the choice is deterministic regardless of dict insertion
   order). Mirrors the openclaw handling at openclaw/.env.j2:55-71.

   `default({})` guards against an undefined or None `integrations` var so
   the template never raises mid-render. Integration names are validated
   upstream by INTEGRATION_NAME_PATTERN in core/integrations.py (must start
   with a letter, alphanumeric + `_-` only); the `regex_replace` below is
   defense-in-depth so the env-var key cannot contain anything outside
   `[A-Z0-9_]` even if a future code path bypasses that validator. #}
{# `default({}, true)` (note the boolean=true) coerces both undefined AND
   falsy values (None, []) to the empty dict, not just undefined. Plain
   `default({})` would let `None` through and crash on the `length` call. #}
{% set _integrations = integrations | default({}, true) %}
{% if _integrations | length > 0 %}
{% for name, integration in _integrations | dictsort %}
{% if integration.type == 'github' and integration.GITHUB_TOKEN is defined %}
GITHUB_TOKEN_{{ name | upper | replace('-', '_') | regex_replace('[^A-Z0-9_]', '') }}={{ shell_quote(integration.GITHUB_TOKEN) }}
GITHUB_TOKEN={{ shell_quote(integration.GITHUB_TOKEN) }}
{% endif %}
{% endfor %}
{% endif %}
