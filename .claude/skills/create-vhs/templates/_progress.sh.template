# Per-demo helper script. Sets the per-demo variables, then sources the shared
# card/headline/progress functions from docs/demos/lib/cards.sh.
#
# Copy to docs/demos/YYYYMMDD-<NAME>/helpers.sh and fill in the FILL-IN markers.
# Keep _SCENES in sync with docs/demos/YYYYMMDD-<NAME>/storyboard.md.

# FILL IN: one quoted scene title per line, in order. Order = playback order.
_SCENES=(
  "clawctl version"
  "Scene Two"
)

# FILL IN: titles rendered on the cards.
_TITLE="Demo Title"
_SUBTITLE="a clawctl demo"
_OUTRO_LINE_1="Thanks for watching!"
_OUTRO_LINE_2="github.com/ric03uec/clawrium"

# Source shared card/headline/progress functions.
source "$(git rev-parse --show-toplevel)/docs/demos/lib/cards.sh"
