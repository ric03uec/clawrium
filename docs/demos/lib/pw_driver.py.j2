"""Playwright driver for the {{ title }} demo."""
from __future__ import annotations

import subprocess
import sys
import time
from pathlib import Path

from playwright.sync_api import Page, sync_playwright


DEMO_DIR = Path(__file__).resolve().parent
VIEWPORT = {"width": {{ tape.width }}, "height": {{ tape.height }}}
BASE_URL = {{ tape.base_url | repr }}
COLOR_SCHEME = {{ tape.color_scheme | repr }}
REDUCED_MOTION = {{ tape.reduced_motion | repr }}


def main() -> int:
    video_dir = DEMO_DIR / "_video_raw"
    video_dir.mkdir(exist_ok=True)
    for old in video_dir.glob("*.webm"):
        old.unlink()

    with sync_playwright() as pw:
        browser = pw.chromium.launch(headless=True, channel="chrome")
        context = browser.new_context(
            viewport=VIEWPORT,
            record_video_dir=str(video_dir),
            record_video_size=VIEWPORT,
            color_scheme=COLOR_SCHEME,
            reduced_motion=REDUCED_MOTION,
        )
        page = context.new_page()

{% if has_title_card %}
        # ---- intro title card ----
        title_uri = (DEMO_DIR / "cards" / "title.html").as_uri()
        page.goto(title_uri, wait_until="domcontentloaded")
        page.wait_for_timeout({{ (intro.title_card.hold_seconds * 1000) | int }})

{% endif %}
        # ---- initial app load ----
        page.goto(BASE_URL.rstrip("/") + "/", wait_until="domcontentloaded")
        page.wait_for_timeout(500)

        # ---- scenes ----
{% for scene in scenes %}
        play_scene_{{ "%02d" % scene.n }}(page)
{% endfor %}

{% if has_outro_card %}
        # ---- outro card ----
        outro_uri = (DEMO_DIR / "cards" / "outro.html").as_uri()
        page.goto(outro_uri, wait_until="domcontentloaded")
        page.wait_for_timeout({{ (outro_card.hold_seconds * 1000) | int }})

{% endif %}
        context.close()
        browser.close()

    return finalize_recording()


{% for scene in scenes %}
def play_scene_{{ "%02d" % scene.n }}(page: Page) -> None:
    """[scene {{ "%02d" % scene.n }}] {{ scene.title }}"""
    print({{ ("[scene %02d] " % scene.n + scene.title) | repr }}, flush=True)
    start = time.monotonic()
{% for line in scene.action_lines %}
    {{ line }}
{% endfor %}
    elapsed = time.monotonic() - start
    remaining = max(0.0, {{ scene.screen_seconds | float }} - elapsed)
    page.wait_for_timeout(int(remaining * 1000))


{% endfor %}
def finalize_recording() -> int:
    video_dir = DEMO_DIR / "_video_raw"
    webms = sorted(video_dir.glob("*.webm"))
    if not webms:
        print("ERROR: Playwright produced no WebM", file=sys.stderr)
        return 1
    target_webm = DEMO_DIR / "recording.webm"
    webms[-1].replace(target_webm)
    for stray in video_dir.glob("*"):
        stray.unlink()
    video_dir.rmdir()
    print(f"Recorded: {target_webm.name}")

    target_mp4 = DEMO_DIR / "recording.mp4"
    subprocess.run(
        [
            "ffmpeg", "-y",
            "-i", str(target_webm),
            "-c:v", "libx264",
            "-pix_fmt", "yuv420p",
            "-crf", "20",
            "-preset", "fast",
            "-loglevel", "error",
            str(target_mp4),
        ],
        check=True,
    )
    print(f"Transcoded: {target_mp4.name}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
