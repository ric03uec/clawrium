<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ title }} — outro</title>
  <style>
    html, body { height: 100%; margin: 0; }
    body {
      background: radial-gradient(ellipse at center, #0f1f1a 0%, #050807 70%);
      color: #f9fafb;
      font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 1rem;
      padding: 4rem;
      box-sizing: border-box;
    }
    .brand {
      font-size: 1rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: #6ee7b7;
      font-weight: 600;
      margin-bottom: 0.75rem;
    }
    h2 {
      font-size: 3.25rem;
      margin: 0 0 2rem;
      color: #ecfdf5;
      letter-spacing: -0.02em;
      font-weight: 600;
      text-align: center;
    }
    .links {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.85rem;
      font-family: ui-monospace, "JetBrains Mono", "SF Mono", Menlo, monospace;
      font-size: 1.55rem;
      color: #d1d5db;
    }
    .links .arrow {
      color: #6ee7b7;
      margin-right: 0.5em;
    }
  </style>
</head>
<body>
  <div class="brand">Clawrium</div>
  <h2>Try it yourself.</h2>
  <div class="links">
    <div><span class="arrow">→</span>{{ outro.line_1 }}</div>
    <div><span class="arrow">→</span>{{ outro.line_2 }}</div>
  </div>
</body>
</html>
