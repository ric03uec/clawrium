{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawrium.dev/schemas/agent-skill.schema.json",
  "title": "Agentskills.io skill (SKILL.md frontmatter)",
  "description": "Flat single-file skill descriptor. The YAML frontmatter at the top of SKILL.md is the canonical source; the markdown body below is the skill content.",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "description": "Slug. Globally unique across vetted/ and local/ sources."
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "platforms": {
      "type": "array",
      "items": {"type": "string"}
    },
    "prerequisites": {
      "type": "object"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cadence": {"type": "string"},
        "trigger": {"type": "string"},
        "outputs": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
